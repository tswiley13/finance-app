{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "image": "latest" }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": true, "image": "latest" }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": { "image": "latest" }
    }
  },
  "submit": {
    "production": {}
  }
}
